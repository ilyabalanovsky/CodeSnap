{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapScript",
  "version": "0.1.0",
  "identifier": "dev.snapscript.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SnapScript",
        "width": 1120,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Beautiful code screenshots for desktop.",
    "longDescription": "SnapScript creates professional PNG screenshots of selected code from a lightweight Tauri desktop app."
  }
}
